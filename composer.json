{
  "name": "hlm/ai-seo",
  "description": "AI-readable website exports (llms.txt & llms-full.txt) for LLMs and AI tools",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "HLM Team",
      "email": "dev@hlm.dev",
      "homepage": "https://hlm.dev"
    }
  ],
  "keywords": [
    "wordpress",
    "plugin",
    "ai",
    "seo",
    "llms",
    "export"
  ],
  "autoload": {
    "psr-4": {
      "HLM\\AiSeo\\": "src/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
